{
  "id": "rules.swimming.basic-tracking-csv",
  "title": "Swimming basic tracking CSV",
  "delimiter": ",",
  "allowExtraColumns": false,
  "columns": [
    {
      "name": "frameId",
      "type": "integer",
      "required": true,
      "min": 0
    },
    {
      "name": "swimmerId",
      "type": "integer",
      "required": true,
      "min": 0
    },
    {
      "name": "eventId",
      "type": "string",
      "required": true,
      "catalog": "swimming.annotation-events"
    },
    {
      "name": "time",
      "type": "number",
      "required": true,
      "min": 0
    },
    {
      "name": "distance",
      "type": "number",
      "required": true,
      "min": 0,
      "max": 50
    }
  ],
  "groupBy": [
    "swimmerId"
  ],
  "groupRules": [
    {
      "id": "frame-monotonic",
      "check": "monotonic",
      "column": "frameId",
      "direction": "increasing",
      "severity": "error"
    },
    {
      "id": "time-monotonic",
      "check": "monotonic",
      "column": "time",
      "direction": "increasing",
      "severity": "error"
    },
    {
      "id": "distance-monotonic",
      "check": "monotonic",
      "column": "distance",
      "direction": "nondecreasing",
      "severity": "error"
    }
  ]
}
